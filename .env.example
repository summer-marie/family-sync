# Neon Postgres
# Use pooled URL for runtime, direct URL for migrations (read automatically by Prisma 7)
DATABASE_URL="postgresql://..."
DIRECT_URL="postgresql://..."

# Auth.js v5
AUTH_SECRET=""
AUTH_GOOGLE_ID=""
AUTH_GOOGLE_SECRET=""

OPENAI_API_KEY="" # Add your OpenAI API key here

# AI model key — add when Vercel AI SDK is wired

RESEND_API_KEY=re_...
# Local dev default below. Code requires this var explicitly (no fallback) —
# set your own verified sender domain in Vercel for production.
RESEND_FROM_EMAIL=onboarding@resend.dev
# Local dev default below. Code requires this var explicitly (no fallback) —
# set your real production URL in Vercel.
NEXTAUTH_URL=http://localhost:3000
