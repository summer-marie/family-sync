datasource db {
  provider = "postgresql"
}

generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

model User {
  id            String    @id @default(cuid())
  name          String?
  email         String    @unique
  emailVerified DateTime?
  image         String?
  accounts            Account[]
  sessions            Session[]
  memberships         GroupMembership[]
  calendarConnections CalendarConnection[]
  sharedNoteUpdates   SharedNote[]
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt
}

model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String?
  access_token      String?
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String?
  session_state     String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model VerificationToken {
  identifier String
  token      String
  expires    DateTime

  @@unique([identifier, token])
}

// ---------------------------------------------------------------------------
// Family group and membership (Step 2 - spec 003)
//
// MVP rules:
// - A user can belong to at most one family group, enforced at the DB level
//   by the @@unique([userId]) constraint on GroupMembership below.
// - Family ownership and access control come from persisted membership
//   records only. Invite codes/emails are onboarding helpers, not the source
//   of truth.
//
// v2 upgrade notes:
// - To allow a user to join multiple family groups, drop the
//   @@unique([userId]) constraint on GroupMembership. Keep the composite
//   unique [familyGroupId, userId] so membership remains explicit.
// - The session may then need to carry a selected familyId, and auth
//   callbacks would need updating. That is a protected-area change requiring
//   explicit confirmation per AGENTS.md.
// ---------------------------------------------------------------------------

model FamilyGroup {
  id          String           @id @default(cuid())
  name        String
  createdAt   DateTime         @default(now())
  updatedAt   DateTime         @updatedAt
  memberships GroupMembership[]
  invites     Invite[]
  sharedNote  SharedNote?

  @@map("family_group")
}

model GroupMembership {
  id            String     @id @default(cuid())
  familyGroupId String
  userId        String
  role          Role       @default(MEMBER)
  createdAt     DateTime   @default(now())

  familyGroup FamilyGroup @relation(fields: [familyGroupId], references: [id], onDelete: Cascade)
  user        User        @relation(fields: [userId], references: [id], onDelete: Cascade)

  // Composite unique: a user can be a member of a given group at most once.
  @@unique([familyGroupId, userId])

  // MVP-only: enforce one family group per user. See v2 upgrade notes above.
  @@unique([userId])

  @@map("group_membership")
}

enum Role {
  ORGANIZER
  MEMBER
}

// ---------------------------------------------------------------------------
// Lightweight invite helper (Step 2 - spec 003, extended Step 7 - spec 007)
//
// MVP scope:
// - Email-based invites with expiry and a unique token for accept links.
// - Membership is created only when an invited user accepts via the token link.
// - Invites are not the source of truth for access — GroupMembership is.
// - Duplicate invites for the same email within a group are rejected via the
//   @@unique([familyGroupId, email]) constraint.
// - On acceptance, status is set to ACCEPTED rather than deleting the row,
//   so the Members page can show invite history.
// ---------------------------------------------------------------------------

enum InviteStatus {
  PENDING
  ACCEPTED
}

model Invite {
  id            String       @id @default(cuid())
  familyGroupId String
  email         String
  role          Role         @default(MEMBER)
  token         String       @unique @default(cuid())
  status        InviteStatus @default(PENDING)
  createdAt     DateTime     @default(now())
  expiresAt     DateTime

  familyGroup FamilyGroup @relation(fields: [familyGroupId], references: [id], onDelete: Cascade)

  @@unique([familyGroupId, email])

  @@map("invite")
}

// ---------------------------------------------------------------------------
// Calendar connection (Step 3 - spec 002 / Step 4 - spec 004)
//
// MVP rules:
// - One Google Calendar connection per user, enforced by
//   @@unique([userId, provider]). For MVP, provider is always "google".
// - Calendar data is fetched live from Google on request (pull-on-demand).
//   No background sync, no webhooks, no Neon mirror as the default.
//
// Visibility (Step 4 - spec 004):
// - Binary per connection: FULL exposes event titles; BUSY_ONLY replaces
//   all titles with "Busy" before any schedule output or AI prompt is built.
// - Default is FULL (user opts in to privacy, not out of it).
// - applyPrivacyFilter in src/lib/schedule/privacy.ts enforces this rule.
//
// Failed/expired reads:
// - On a failed or expired Google read, the service returns a privacy-safe
//   `unavailable` state rather than leaking partial or stale data.
// - There is NO silent token auto-refresh. Reconnect = the user
//   re-authenticates via Google OAuth.
// ---------------------------------------------------------------------------

model CalendarConnection {
  id              String           @id @default(cuid())
  userId          String
  provider        String           @default("google")
  status          ConnectionStatus @default(CONNECTED)
  visibility      Visibility       @default(FULL)
  lastConnectedAt DateTime         @default(now())
  createdAt       DateTime         @default(now())
  updatedAt       DateTime         @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  // MVP: one connection per user per provider (effectively one google
  // connection per user).
  @@unique([userId, provider])

  @@map("calendar_connection")
}

enum ConnectionStatus {
  CONNECTED
  DISCONNECTED
  ERROR
}

enum Visibility {
  FULL
  BUSY_ONLY
}

// ---------------------------------------------------------------------------
// Shared family note (Step 6 - spec 005)
//
// MVP rules:
// - One note per family group, enforced at the DB level by @unique on
//   familyGroupId.
// - Content defaults to empty string; an empty note is valid.
// - updatedByUserId tracks the last editor. No history is stored for MVP.
// - onDelete: Cascade on the family group relation: deleting the group also
//   deletes the note.
// ---------------------------------------------------------------------------

model SharedNote {
  id              String   @id @default(cuid())
  familyGroupId   String   @unique
  content         String   @default("")
  updatedAt       DateTime @updatedAt
  updatedByUserId String

  familyGroup FamilyGroup @relation(fields: [familyGroupId], references: [id], onDelete: Cascade)
  updatedBy   User        @relation(fields: [updatedByUserId], references: [id])

  @@map("shared_note")
}
